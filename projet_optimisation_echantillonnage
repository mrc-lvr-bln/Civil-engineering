# ─────────────────────────────────────────────
if __name__ == '__main__':
    freqs_test = [25, 40, 50, 60, 75, 100, 125, 150]

    print(" Analyse des fréquences d'échantillonnage...")
    df_freqs = analyser_frequences(freqs_test, n_simulations=3_000)

    print(" Optimisation numérique...")
    freq_opt, cout_opt = trouver_freq_optimale(n_simulations=2_000)

    print(f"\n{'='*55}")
    print(f"  OPTIMISATION – PLAN D'ÉCHANTILLONNAGE")
    print(f"{'='*55}")
    print(f"  Volume total         : {VOLUME_BETON_M3_PAR_JOUR * JOURS_CHANTIER:,} m³")
    print(f"  Fréquence optimale   : 1 essai / {freq_opt:.0f} m³")
    n_ess_opt = int((VOLUME_BETON_M3_PAR_JOUR * JOURS_CHANTIER) / freq_opt)
    print(f"  Nombre d'essais      : {n_ess_opt}")
    print(f"  Coût espéré          : ${cout_opt:,.0f} CAD")
    print(f"{'='*55}")
    print("\n  Tableau comparatif des fréquences :")
    print(df_freqs[['freq_m3','n_essais','cout_moyen','cout_q10','cout_q90']].to_string(
        index=False, float_format=lambda x: f'{x:,.0f}'))
    print()

    tracer_rapport_optimisation(df_freqs, freq_opt, cout_opt)

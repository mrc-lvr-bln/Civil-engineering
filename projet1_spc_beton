# Calcul des indicateurs de capabilité
cp = (limites['UCL_x'] - limites['LCL_x']) / (6 * df['moy'].std())
cpk = min(
    (limites['UCL_x'] - df['moy'].mean()) / (3 * df['moy'].std()),
    (df['moy'].mean() - limites['LCL_x']) / (3 * df['moy'].std())
)

ax1.set_xlabel('Numéro de lot', color=couleur_texte, fontsize=9)
ax1.set_ylabel('Résistance moyenne (MPa)', color=couleur_texte, fontsize=9)
legend = ax1.legend(loc='lower left', fontsize=8, facecolor=couleur_fond,

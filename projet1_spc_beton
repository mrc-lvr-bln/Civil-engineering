def styler_axes(ax, titre):
    ax.set_facecolor(couleur_fond)
    ax.spines['bottom'].set_color(couleur_grille)
    ax.spines['left'].set_color(couleur_grille)
    ax.spines['top'].set_visible(False)
    ax.spines['right'].set_visible(False)
    ax.tick_params(colors=couleur_texte, labelsize=9)
    ax.set_title(titre, color=couleur_texte, fontsize=11, fontweight='bold', pad=10)
    ax.grid(True, color=couleur_grille, alpha=0.5, linestyle='--', linewidth=0.5)


# ─────────────────────────────────────────────
# 1. SIMULATION DE DONNÉES D'ESSAIS DE BÉTON
# ─────────────────────────────────────────────

def simuler_donnees_beton(n_lots=40, n_eprouvettes=3, fc_cible=35, ecart_type=2.5):
    """
    Simule des données de résistance à la compression (MPa).
    - fc_cible : résistance nominale en MPa (ex: béton 35 MPa)
    - n_eprouvettes : cylindres testés par lot (28 jours)
    - Introduit 3 anomalies réalistes (mauvais dosage eau/ciment)
    """
    donnees = []
    for lot in range(1, n_lots + 1):
        # Légère dérive simulée après lot 25 (changement fournisseur ciment)
        derive = -1.5 if lot > 25 else 0
        # Anomalies ponctuelles
        anomalie = -8 if lot in [12, 31, 37] else 0
        
        resistances = np.random.normal(
            loc=fc_cible + derive + anomalie,
            scale=ecart_type,
            size=n_eprouvettes
        )
        donnees.append({
            'lot': lot,
            'date': pd.Timestamp('2024-06-01') + pd.Timedelta(days=lot * 2),
            'moy': np.mean(resistances),
            'etendue': np.max(resistances) - np.min(resistances),
            'ecart_type': np.std(resistances, ddof=1),
            'min_resistance': np.min(resistances)
        })
    return pd.DataFrame(donnees)

df = simuler_donnees_beton()

# ─────────────────────────────────────────────
# 2. CALCUL DES LIMITES DE CONTRÔLE (SPC)
# ─────────────────────────────────────────────

def calculer_limites_xbar_R(df, n=3):
    """
    Cartes X̄-R selon constantes SPC (n=3 cylindres/lot).
    Constantes : A2=1.023, D3=0, D4=2.574 pour n=3
    """
    A2, D3, D4 = 1.023, 0, 2.574  # n=3
    
    # Exclure les anomalies pour calculer les limites de base
    df_base = df[(df['lot'] <= 20)]  # Phase I : 20 premiers lots stables
    
    X_bar_bar = df_base['moy'].mean()
    R_bar = df_base['etendue'].mean()
    
    # Carte X̄
    UCL_x = X_bar_bar + A2 * R_bar
    LCL_x = X_bar_bar - A2 * R_bar
    
    # Carte R
    UCL_r = D4 * R_bar
    LCL_r = D3 * R_bar  # = 0 pour n=3
    
    return {
        'X_bar_bar': X_bar_bar,
        'R_bar': R_bar,
        'UCL_x': UCL_x,
        'LCL_x': LCL_x,
        'UCL_r': UCL_r,
        'LCL_r': LCL_r,
        'fc_min_CSA': 0.85 * 35  # CSA A23.1: min individuel = 0.85 * f'c
    }

limites = calculer_limites_xbar_R(df)

# ─────────────────────────────────────────────
# 3. DÉTECTION AUTOMATIQUE DES VIOLATIONS
# ─────────────────────────────────────────────

def detecter_violations(df, limites):
    """
    Règles de Nelson / Western Electric :
    Règle 1 : Point hors limites ±3σ
    Règle 2 : 8 points consécutifs du même côté de la moyenne
    Règle 3 : 6 points consécutifs monotones (dérive)
    """
    violations = pd.DataFrame({'lot': df['lot']})
    
    # Règle 1 — hors limites
    violations['hors_limites'] = (
        (df['moy'] > limites['UCL_x']) | (df['moy'] < limites['LCL_x'])
    )
    
    # Règle 2 — 8 points du même côté
    au_dessus = (df['moy'] > limites['X_bar_bar']).astype(int)
    en_dessous = (df['moy'] < limites['X_bar_bar']).astype(int)
    violations['derive_8pts'] = False
    for i in range(7, len(df)):
        if au_dessus.iloc[i-7:i+1].sum() == 8 or en_dessous.iloc[i-7:i+1].sum() == 8:
            violations.loc[violations.index[i], 'derive_8pts'] = True
    
    # Règle 3 — dérive monotone 6 points
    violations['tendance'] = False
    for i in range(5, len(df)):
        segment = df['moy'].iloc[i-5:i+1].values
        if all(np.diff(segment) > 0) or all(np.diff(segment) < 0):
            violations.loc[violations.index[i], 'tendance'] = True
    
    # Conformité CSA : résistance min individuelle
    violations['non_conforme_CSA'] = df['min_resistance'] < limites['fc_min_CSA']
    
    return violations

violations = detecter_violations(df, limites)
df = df.merge(violations, on='lot')

# ─────────────────────────────────────────────

    ['Violations règles Nelson', str(n_violations), '0', '✓ OK' if n_violations == 0 else f'⚠ {n_violations} détectée(s)'],
    ['X̄ global (MPa)', f"{df['moy'].mean():.2f}", f'≥ {limites["X_bar_bar"]:.1f}', '✓'],

# ── Histogramme + courbe normale ────────────
ax3 = fig.add_subplot(gs[1, 1])
styler_axes(ax3, 'Distribution des résistances')

mu, sigma_obs = df['moy'].mean(), df['moy'].std()
ax3.hist(df['moy'], bins=12, color=couleur_bleu, alpha=0.7, edgecolor='white',

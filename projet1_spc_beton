# ── Carte R ────────────────────────────────
ax2 = fig.add_subplot(gs[1, 0])
styler_axes(ax2, 'Carte R  —  Étendue par lot')

ax2.plot(df['lot'], df['etendue'], color='#a5d6ff', linewidth=1.5,
